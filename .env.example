# Contact form delivery: /api/contact validates the submission and forwards
# it server-side to an n8n webhook, which writes the lead into Airtable.
# Going through this proxy avoids browser-to-n8n CORS.

# n8n production webhook URL (yd-lead-intake workflow).
N8N_WEBHOOK_URL=https://n8n-production-5418.up.railway.app/webhook/yd-lead-intake

# Upstash Redis credentials power the /api/contact rate limiter (5 req / 60s
# per IP). Required in production; locally the limiter no-ops when unset.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Analytics IDs — both are public-by-design (rendered into the client
# bundle) and are safe to set in Vercel project env. Leaving them empty
# is the supported "off" mode: the app loads no third-party scripts.

# Google Analytics 4 measurement ID, e.g. G-XXXXXXXXXX
VITE_GA4_ID=

# Microsoft Clarity project ID, e.g. abcd1234ef
VITE_CLARITY_ID=

# Google Search Console verification token
# Set this in your hosting provider's environment variables.
# Leave blank locally — verification is only needed in production.
VITE_GSC_VERIFICATION=

# Cloudflare Web Analytics (privacy-friendly site analytics)
# Public identifier; appears in every rendered page. Not a secret.
# Set in your hosting provider's env vars to enable analytics.
# Leave blank locally — analytics is only meaningful in production.
VITE_CLOUDFLARE_BEACON_TOKEN=
