# Contact form delivery via Resend.
# Required for /api/contact to send leads.

# Get one at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx

# Where leads are delivered. Defaults to yuvalzakay25@gmail.com if unset.
CONTACT_TO_EMAIL=yuvalzakay25@gmail.com

# Sender shown in the inbox. MUST be on a domain you verified in Resend
# (https://resend.com/domains). Until you verify a domain, use the shared
# sandbox sender below — it works only for delivery to the email you signed
# up to Resend with.
CONTACT_FROM_EMAIL="Yuval Digital <onboarding@resend.dev>"
